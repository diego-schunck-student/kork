{
  "title": "Projeto Korp - Dashboard",
  "refresh": "10s",
  "time": {
    "from": "now-5m",
    "to": "now"
  },
  "schemaVersion": 36,
  "panels": [
    {
      "type": "stat",
      "title": "Disponibilidade do Serviço",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "expr": "up{job=\"projeto-korp\"}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                },
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 1
                }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "null",
                "result": {
                  "text": "OFFLINE",
                  "color": "red",
                  "index": 2
                }
              }
            },
            {
              "type": "special",
              "options": {
                "match": "empty",
                "result": {
                  "text": "OFFLINE",
                  "color": "red",
                  "index": 3
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Volume de Requisições",
      "datasource": "Prometheus",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "refId": "A"
        }
      ]
    }
  ]
}
