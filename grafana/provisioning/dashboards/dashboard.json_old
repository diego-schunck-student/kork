    },
    {
      "type": "timeseries",
      "title": "Volume de Requisições",
      "targets": [{"expr": "rate(http_requests_total[1m])"}],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    }
  ],
  "schemaVersion": 36
}
